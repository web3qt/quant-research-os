#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

source "$SCRIPT_DIR/qros-wrapper-lib"
PYTHON_BIN="$(qros_select_python_bin "$SCRIPT_DIR")"
qros_verify_runtime_lock "$SCRIPT_DIR" "$PYTHON_BIN"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

cd "$TARGET_CWD"
if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/audit_reviewer_write_scope.py" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/audit_reviewer_write_scope.py"
