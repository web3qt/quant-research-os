#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      echo "qros-progress does not accept --outputs-root; it is derived from the project root" >&2
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

PROJECT_ROOT="$(cd "$TARGET_CWD" && pwd)"

PYTHON_BIN=""
for CANDIDATE in python python3; do
  if command -v "$CANDIDATE" >/dev/null 2>&1 && "$CANDIDATE" - <<'PY' >/dev/null 2>&1
import sys
import tomllib

raise SystemExit(0 if sys.version_info >= (3, 11) else 1)
PY
  then
    PYTHON_BIN="$CANDIDATE"
    break
  fi
done

if [ -z "$PYTHON_BIN" ]; then
  echo "qros-progress requires Python 3.11+ with tomllib support" >&2
  exit 1
fi

source "$SCRIPT_DIR/qros-wrapper-lib"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

cd "$PROJECT_ROOT"
exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_progress.py" --outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}"
