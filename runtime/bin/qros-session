#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      echo "qros-session does not accept --outputs-root; it is derived from the project root" >&2
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

PROJECT_ROOT="$(cd "$TARGET_CWD" && pwd)"

select_python_bin() {
  local candidates=()
  if [ -n "${QROS_PYTHON:-}" ]; then
    candidates+=("$QROS_PYTHON")
  fi
  candidates+=("python" "python3")

  local candidate
  for candidate in "${candidates[@]}"; do
    if ! command -v "$candidate" >/dev/null 2>&1; then
      continue
    fi
    if "$candidate" - <<'PY' >/dev/null 2>&1
import sys

raise SystemExit(0 if sys.version_info >= (3, 11) else 1)
PY
    then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  echo "QROS requires Python >=3.11; set QROS_PYTHON or put a compatible python/python3 on PATH" >&2
  return 1
}

PYTHON_BIN="$(select_python_bin)"

source "$SCRIPT_DIR/qros-wrapper-lib"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

cd "$PROJECT_ROOT"
set +e
if [ "${#ARGS[@]}" -gt 0 ]; then
  "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}"
else
  "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs"
fi
STATUS=$?
set -e
case "$STATUS" in
  2|3|4|5|6|7|8)
    exit 0
    ;;
  *)
    exit "$STATUS"
    ;;
esac
