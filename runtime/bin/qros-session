#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      echo "qros-session does not accept --outputs-root; it is derived from the project root" >&2
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

PROJECT_ROOT="$(cd "$TARGET_CWD" && pwd)"

source "$SCRIPT_DIR/qros-wrapper-lib"
PYTHON_BIN="$(qros_select_python_bin "$SCRIPT_DIR")"
qros_verify_runtime_lock "$SCRIPT_DIR" "$PYTHON_BIN"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

cd "$PROJECT_ROOT"
set +e
if [ "${#ARGS[@]}" -gt 0 ]; then
  "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}"
else
  "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs"
fi
STATUS=$?
set -e
case "$STATUS" in
  2|3|4|5|6|7|8)
    exit 0
    ;;
  *)
    exit "$STATUS"
    ;;
esac
