#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()
HAS_OUTPUTS_ROOT=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      HAS_OUTPUTS_ROOT=1
      ARGS+=("$1" "$2")
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

source "$SCRIPT_DIR/qros-wrapper-lib"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

PROJECT_ROOT="$(cd "$TARGET_CWD" && pwd)"
cd "$PROJECT_ROOT"

if [ "$HAS_OUTPUTS_ROOT" -eq 0 ]; then
  ARGS=(--outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}")
fi

exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/validate_stage_artifacts.py" "${ARGS[@]}"
