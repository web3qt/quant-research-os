#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

select_python_bin() {
  local candidates=()
  if [ -n "${QROS_PYTHON:-}" ]; then
    candidates+=("$QROS_PYTHON")
  fi
  candidates+=("python" "python3")

  local candidate
  for candidate in "${candidates[@]}"; do
    if ! command -v "$candidate" >/dev/null 2>&1; then
      continue
    fi
    if "$candidate" - <<'PY' >/dev/null 2>&1
import sys

raise SystemExit(0 if sys.version_info >= (3, 11) else 1)
PY
    then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  echo "QROS requires Python >=3.11; set QROS_PYTHON or put a compatible python/python3 on PATH" >&2
  return 1
}

PYTHON_BIN="$(select_python_bin)"

source "$SCRIPT_DIR/qros-wrapper-lib"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" strict)"

cd "$TARGET_CWD"
if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_stage_review.py" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_stage_review.py"
