#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -d "$SCRIPT_DIR/../scripts" ]; then
  RUNTIME_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -d "$SCRIPT_DIR/../../runtime/scripts" ]; then
  RUNTIME_ROOT="$(cd "$SCRIPT_DIR/../../runtime" && pwd)"
else
  echo "Unable to locate QROS runtime root from $SCRIPT_DIR" >&2
  exit 1
fi

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

cd "$TARGET_CWD"
if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_stage_review.py" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_stage_review.py"
