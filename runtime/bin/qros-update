#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TARGET_CWD="$PWD"
HOST="auto"
HOST_EXPLICIT=0
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --host)
      HOST="$2"
      HOST_EXPLICIT=1
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

source "$SCRIPT_DIR/qros-wrapper-lib"
RUNTIME_ROOT="$(qros_resolve_runtime_root "$SCRIPT_DIR" "$PYTHON_BIN" recovery)"

cd "$TARGET_CWD"
HOST_ARGS=(--host "$HOST")
if [ "$HOST_EXPLICIT" -eq 1 ]; then
  HOST_ARGS+=(--host-explicit)
fi

if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_qros_update.py" --cwd "$TARGET_CWD" "${HOST_ARGS[@]}" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$RUNTIME_ROOT/scripts/run_qros_update.py" --cwd "$TARGET_CWD" "${HOST_ARGS[@]}"
