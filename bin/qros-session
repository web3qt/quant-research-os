#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      echo "qros-session does not accept --outputs-root; it is derived from the project root" >&2
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if git -C "$TARGET_CWD" rev-parse --show-toplevel >/dev/null 2>&1; then
  PROJECT_ROOT="$(git -C "$TARGET_CWD" rev-parse --show-toplevel)"
else
  PROJECT_ROOT="$TARGET_CWD"
fi

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

cd "$PROJECT_ROOT"
if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$REPO_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs"
