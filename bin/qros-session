#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    --outputs-root)
      echo "qros-session does not accept --outputs-root; it is derived from the project root" >&2
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

PROJECT_ROOT="$(cd "$TARGET_CWD" && pwd)"

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

cd "$PROJECT_ROOT"
set +e
if [ "${#ARGS[@]}" -gt 0 ]; then
  "$PYTHON_BIN" "$REPO_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs" "${ARGS[@]}"
else
  "$PYTHON_BIN" "$REPO_ROOT/scripts/run_research_session.py" --outputs-root "$PROJECT_ROOT/outputs"
fi
STATUS=$?
set -e
case "$STATUS" in
  2|3|4|5|6|7|8)
    exit 0
    ;;
  *)
    exit "$STATUS"
    ;;
esac
