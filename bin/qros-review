#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TARGET_CWD="$PWD"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      TARGET_CWD="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

cd "$TARGET_CWD"
if [ "${#ARGS[@]}" -gt 0 ]; then
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/run_stage_review.py" "${ARGS[@]}"
fi

exec "$PYTHON_BIN" "$REPO_ROOT/scripts/run_stage_review.py"
