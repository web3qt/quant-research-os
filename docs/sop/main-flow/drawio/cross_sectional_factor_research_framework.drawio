    <diagram id="cross-sectional-factor-flow" name="Flow">
        <mxGraphModel dx="2787" dy="735" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4600" pageHeight="2200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="fl_title" value="横截面因子研究流程: 正式阶段与阶段内方法步骤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=22;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="24" width="700" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="fl_meta" value="关键结论&#xa;上层是正式阶段；下层是各阶段里的研究动作。&#xa;10 多个动作不等于 10 多个正式阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=14;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="120" y="40" width="520" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="fl_gov" value="共享治理层&#xa;想法准入 / 研究立项 / 晋级决策 / 变更纪律 / 审查状态词汇&#xa;横截面因子路线只是在立项之后进入独立正式流程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="3490" y="40" width="860" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="fl_stage_band" value="上层: 正式阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;fontSize=16;" vertex="1" parent="1">
                    <mxGeometry x="120" y="180" width="4230" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="fl_step_band" value="下层: 各阶段内的方法步骤 / 证据对象" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontStyle=1;fontSize=16;" vertex="1" parent="1">
                    <mxGeometry x="120" y="500" width="4230" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="fl_art_band" value="底层: 关键 Artifact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontStyle=1;fontSize=16;" vertex="1" parent="1">
                    <mxGeometry x="120" y="1120" width="4230" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="fl1" value="立项阶段&#xa;冻结研究身份 / 排序目标 /&#xa;持有周期 / 主证据合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="120" y="260" width="240" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fl2" value="数据就绪阶段&#xa;搭好截面研究底座" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="430" y="260" width="220" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fl3" value="信号就绪阶段&#xa;冻结因子面板合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="720" y="260" width="220" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fl4" value="训练冻结阶段&#xa;冻结截面尺子" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="260" width="220" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fl5" value="测试证据阶段&#xa;验证独立样本排序证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="260" width="240" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fld1" value="测试证据成立?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;fontStyle=1;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1605" y="255" width="180" height="102" as="geometry"/>
                </mxCell>
                <mxCell id="fl6" value="回测就绪阶段&#xa;验证组合映射与扣成本后的经济性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1855" y="260" width="270" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fld2" value="回测后仍可做?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;fontStyle=1;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="2195" y="255" width="190" height="102" as="geometry"/>
                </mxCell>
                <mxCell id="fl7" value="留出验证阶段&#xa;最终未参与设计窗口验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="2455" y="260" width="260" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fld3" value="留出验证未翻向/塌陷?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;fontStyle=1;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="2785" y="255" width="200" height="102" as="geometry"/>
                </mxCell>
                <mxCell id="fl8" value="候选策略池&#xa;进入上线候选评估" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontStyle=1;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="3065" y="260" width="230" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="fl_note_right" value="这条上层主线就是你说的“大框架”。&#xa;其中“数据就绪 / 信号就绪 / 训练冻结 / 测试证据 / 回测就绪 / 留出验证”都是正式阶段，不是方法步骤列表。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="3400" y="250" width="950" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="flr1" value="返回上游重做&#xa;研究范围 / 标签定义 / 因子定义 / 资产池&#xa;必要时新开子分支" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontStyle=1;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1530" y="395" width="300" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="flr2" value="不进留出验证&#xa;回退到组合映射 / 约束 / 成本假设&#xa;或淘汰该方案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="2140" y="395" width="320" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="flr3" value="不进候选策略池&#xa;记录留出期失败 / 市场状态变化 / 衰减结论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontStyle=1;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="2750" y="395" width="330" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="fls1" value="立项阶段内要做的事&#xa;- 冻结研究路线 / 因子角色 / 组合表达&#xa;- 写清排序目标与持有周期&#xa;- 冻结主证据合同与容量审计口径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="120" y="590" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="fls2" value="数据就绪阶段内要做的事&#xa;- 构造“日期 x 资产”面板&#xa;- 冻结资产池成员与可交易掩码&#xa;- 检查覆盖率、缺失、分组口径与时间语义" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="450" y="590" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="fls3" value="信号就绪阶段内要做的事&#xa;- 定义因子身份、版本和方向&#xa;- 生成因子面板与覆盖率合同&#xa;- 冻结缺失值处理和最终分数字段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="780" y="590" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="fls4" value="训练冻结阶段内要做的事&#xa;- 预处理 / 去极值 / 标准化 / 中性化&#xa;- 分桶规则 / 分位规则 / 并列处理规则&#xa;- 调仓规则 / 信号滞后 / 重叠规则 / 可保留方案清单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="1110" y="590" width="340" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fls5" value="测试证据阶段内要做的事&#xa;- 排序相关性 / 稳定性 / 分层价差 / 单调性&#xa;- 广度 / 覆盖率 / 分时期稳定性&#xa;- 分市场状态检验 / 多重检验 / 方案台账" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="1490" y="590" width="360" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fls6" value="回测就绪阶段内要做的事&#xa;- 分数映射成组合&#xa;- 中性约束 / 权重规则 / 换手 / 容量&#xa;- 扣成本前后对比 / 单币集中度" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="1900" y="590" width="350" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fls7" value="留出验证阶段内要做的事&#xa;- 只复用冻结方案，不重估尺子&#xa;- 比较留出期与测试期 / 回测期&#xa;- 识别翻向、塌陷、市场状态变化与信号衰减" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="2310" y="590" width="350" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fls8" value="为什么你会觉得像 10 多个阶段&#xa;因为“定义资产池、构造因子、预处理、相关性检验、组合构建、成本分析”这些在研究方法上是独立动作，&#xa;但在这里它们被归入上面的正式阶段内部执行，而不是各自独立成门禁阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="2890" y="590" width="620" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fls9" value="经验法则&#xa;如果一个节点需要冻结合同、产出结论、通过审查才能推进，它是正式阶段。&#xa;如果它只是某个阶段里完成证据的动作，它就是阶段内方法步骤。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="3540" y="590" width="810" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="fla1" value="立项合同 / 立项审查包" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1210" width="260" height="52" as="geometry"/>
