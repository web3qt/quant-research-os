                    <mxGeometry x="430" y="1210" width="280" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="fla3" value="因子面板 / 因子清单 / 覆盖率报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;fontSize=12;fontStyle=1;" parent="1" vertex="1">
