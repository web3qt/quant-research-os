<mxfile host="65bd71144e">
  <diagram id="stage-artifact-mainline" name="Mainline">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2800" pageHeight="2600" math="0" post_holdout_observation="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-main" value="QROS First-Wave Artifact Map&#xa;Mainline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
          <mxGeometry x="980" y="30" width="520" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="common-layout" value="&lt;b&gt;统一目录结构&lt;/b&gt;&lt;br&gt;author/draft：freeze draft、transition approval、分组确认过程件&lt;br&gt;author/formal：正式 stage 产物；真正给下游消费的是这一层&lt;br&gt;review/request：review 输入合同&lt;br&gt;review/result：review 输出与 review_findings&lt;br&gt;review/closure：latest_review_pack、stage_gate_review、stage_completion_certificate&lt;br&gt;&lt;br&gt;&lt;b&gt;常见文件到底是干嘛的&lt;/b&gt;&lt;br&gt;artifact_catalog.md：本阶段文件总目录，先看它知道有哪些产物&lt;br&gt;field_dictionary.md：字段名、含义、单位、约束；读 parquet/json 之前先看它&lt;br&gt;*contract.md：解释这阶段到底冻结了什么，边界是什么&lt;br&gt;*gate_decision.md：说明 formal gate 为什么过/不过，以及下游不能改什么&lt;br&gt;*.json / *.csv：机器可读摘要、台账、清单&lt;br&gt;*.parquet：批量机器数据表；通常不是给人直接逐行读的&lt;br&gt;目录/：一组相关产物或分引擎/分窗口结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEFC;strokeColor=#4A6FA5;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="140" width="780" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="read-order" value="&lt;b&gt;每阶段先看什么&lt;/b&gt;&lt;br&gt;1. author/formal/artifact_catalog.md&lt;br&gt;2. author/formal/field_dictionary.md&lt;br&gt;3. author/formal/*gate_decision.md 或 *contract.md&lt;br&gt;4. 核心 machine artifacts&lt;br&gt;5. review/closure/stage_completion_certificate.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="920" y="140" width="760" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="scope-note" value="&lt;b&gt;范围说明&lt;/b&gt;&lt;br&gt;只覆盖当前 first-wave 已落地编排。&#xa;display 不作为强制推进门，图中不单列 display 阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1740" y="140" width="520" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="idea" value="&lt;b&gt;00 idea_intake&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/00_idea_intake&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：idea_gate_decision → qualification_scorecard → scope_canvas&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：idea_brief.md、observation_hypothesis_map.md、research_question_set.md、scope_canvas.yaml、qualification_scorecard.yaml、idea_gate_decision.yaml、artifact_catalog.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：判断想法是否够资格进入 mandate，并冻结 route assessment 与 kill criteria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="360" width="640" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="mandate" value="&lt;b&gt;00 mandate&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/01_mandate&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → research_route → mandate → time_split&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：mandate.md、research_scope.md、research_route.yaml、time_split.json、parameter_grid.yaml、run_config.toml、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结研究问题、研究路线、时间切分、参数边界和执行合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="760" y="360" width="640" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="data-ready" value="&lt;b&gt;02_tss_data_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/02_tss_data_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → field_dictionary → tss_data_contract → time_index_manifest&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：time_index_manifest.json、asset_time_index.parquet、quality_flags.parquet、split_sample_adequacy_report.yaml、run_manifest.json、rebuild_tss_data_ready.py、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：交付单资产时间序列数据底座、质量语义和 split 样本充分性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="620" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="signal-ready" value="&lt;b&gt;03_tss_signal_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/03_tss_signal_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → signal_manifest → route_inheritance_contract → param_manifest&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：signal_manifest.yaml、param_manifest.csv、signal_panel.parquet、signal_event_panel.parquet、route_inheritance_contract.yaml、run_manifest.json、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结 TSS signal identity、事件锚点、方向语义和 coverage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="760" y="620" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="train-freeze" value="&lt;b&gt;04_tss_train_freeze&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/04_tss_train_freeze&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → tss_train_freeze.yaml → train_threshold_ledger → train_variant_ledger&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：tss_train_freeze.yaml、train_signal_quality.parquet、train_threshold_ledger.csv、train_variant_ledger.csv、train_variant_rejects.csv、run_manifest.json、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结 train window 尺子、阈值、variant 和不可回写规则，供 test 复用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="900" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="test-evidence" value="&lt;b&gt;05_tss_test_evidence&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/05_tss_test_evidence&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → tss_test_contract → tss_test_gate_table → selected_variants&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：forward_return_evidence.parquet、event_outcome_panel.parquet、tss_test_gate_table.csv、tss_selected_variants_test.csv、signal_decay_report.json、run_manifest.json、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结独立样本里的 forward return、hit rate、事件数量和可进入 backtest 的 variant 集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="760" y="900" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="backtest-ready" value="&lt;b&gt;06_tss_backtest_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/06_tss_backtest_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → execution_contract → tss_backtest_gate_table → backtest_summary&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：execution_contract.yaml、tss_backtest_gate_table.csv、backtest_summary.parquet、trade_ledger.csv、turnover_capacity_report.parquet、drawdown_report.json、run_manifest.json、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结 TSS 执行合同，并给出成本后表现、回撤、换手和容量证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="1180" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="holdout-validation" value="&lt;b&gt;07_tss_holdout_validation&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/07_tss_holdout_validation&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → tss_holdout_gate_decision → tss_holdout_run_manifest → holdout_test_compare&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：tss_holdout_run_manifest.json、holdout_signal_diagnostics.parquet、holdout_test_compare.parquet、holdout_backtest_compare.parquet、rolling_holdout_stability.json、regime_shift_audit.json、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：验证最终冻结的 TSS 方案在未参与设计的窗口里是否仍成立，并给出最终 review 输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="760" y="1180" width="640" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="closure-note" value="&lt;b&gt;每阶段共同 review 输出&lt;/b&gt;&lt;br&gt;review/request：adversarial_review_request.yaml、spawned_reviewer_receipt.yaml&lt;br&gt;review/result：adversarial_review_result.yaml、review_findings.yaml&lt;br&gt;review/closure：latest_review_pack.yaml、stage_gate_review.yaml、stage_completion_certificate.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1480" y="360" width="780" height="180" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="stage-artifact-csf" name="CSF">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2800" pageHeight="2400" math="0" post_holdout_observation="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-csf" value="QROS First-Wave Artifact Map&#xa;CSF Route" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6D28D9;fontColor=#FFFFFF;strokeColor=#5B21B6;fontStyle=1;fontSize=24;" parent="1" vertex="1">
          <mxGeometry x="980" y="30" width="520" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="shared-prefix" value="&lt;b&gt;共享前置&lt;/b&gt;&lt;br&gt;`idea_intake` 与 `mandate` 和 mainline 共用。&#xa;只有 `research_route = cross_sectional_factor` 后，才进入下面这条独立 CSF 链。&lt;br&gt;&lt;br&gt;&lt;b&gt;左侧这些文件怎么看&lt;/b&gt;&lt;br&gt;artifact_catalog.md：先看它，确认这一阶段到底交付了哪些文件&lt;br&gt;field_dictionary.md / factor_field_dictionary.md：字段解释，告诉你表里每列是什么意思&lt;br&gt;*contract.md：解释因子/组合/holdout 合同边界&lt;br&gt;*gate_decision.md：说明为什么这一步能过 gate，或还有什么限制&lt;br&gt;*.parquet：大表数据；重点看它承载哪类信息，不是直接人工逐行阅读&lt;br&gt;*.yaml / *.json / *.csv：manifest、ledger、配置、summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="140" width="760" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="read-order-csf" value="&lt;b&gt;每阶段先看什么&lt;/b&gt;&lt;br&gt;1. author/formal/artifact_catalog.md&lt;br&gt;2. author/formal/field_dictionary.md 或 factor_field_dictionary.md&lt;br&gt;3. author/formal/*gate_decision.md / *contract.md&lt;br&gt;4. 核心 parquet/json/csv formal artifacts&lt;br&gt;5. review/closure/stage_completion_certificate.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="900" y="140" width="820" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="csf-data-ready" value="&lt;b&gt;02_csf_data_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/02_csf_data_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → csf_data_contract → panel_manifest → cross_section_coverage → split_sample_adequacy_report&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：panel_manifest.json、asset_universe_membership.parquet、cross_section_coverage.parquet、split_sample_adequacy_report.yaml、eligibility_base_mask.parquet、shared_feature_base/、asset_taxonomy_snapshot.parquet、csf_data_contract.md、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结截面 panel、taxonomy、eligibility、split 样本充足性和共享 feature base" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="330" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="csf-signal-ready" value="&lt;b&gt;03_csf_signal_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/03_csf_signal_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → factor_contract → factor_manifest → factor_panel&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：factor_panel.parquet、factor_manifest.yaml、component_factor_manifest.yaml、factor_coverage_report.parquet、factor_group_context.parquet、factor_contract.md、factor_field_dictionary.md、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结因子 identity、panel contract、expression、context 和 delivery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="840" y="330" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="csf-train-freeze" value="&lt;b&gt;04_csf_train_freeze&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/04_csf_train_freeze&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → csf_train_contract → csf_train_freeze.yaml → train_variant_ledger&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：csf_train_freeze.yaml、train_factor_quality.parquet、train_variant_ledger.csv、train_variant_rejects.csv、train_bucket_diagnostics.parquet、train_neutralization_diagnostics.parquet、csf_train_contract.md、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结 preprocess、中性化、分桶、rebalance 和 train-governable axes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="620" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="csf-test-evidence" value="&lt;b&gt;05_csf_test_evidence&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/05_csf_test_evidence&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → csf_test_contract → csf_test_gate_table → selected_variants&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：rank_ic_timeseries.parquet、rank_ic_summary.json、bucket_returns.parquet、breadth_coverage_report.parquet、subperiod_stability_report.json、csf_test_gate_table.csv、csf_selected_variants_test.csv、csf_test_contract.md、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结独立样本排序证据和可进入 backtest 的 variant 集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="840" y="620" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="csf-backtest-ready" value="&lt;b&gt;06_csf_backtest_ready&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/06_csf_backtest_ready&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → portfolio_contract → csf_backtest_gate_table → turnover_capacity_report&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：portfolio_contract.yaml、portfolio_weight_panel.parquet、rebalance_ledger.csv、turnover_capacity_report.parquet、cost_assumption_report.md、portfolio_summary.parquet、name_level_metrics.parquet、drawdown_report.json、csf_backtest_gate_table.csv、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：冻结组合表达、执行合同、风险覆盖与容量证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="910" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="csf-holdout-validation" value="&lt;b&gt;07_csf_holdout_validation&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot;&gt;目录：outputs/&lt;lineage&gt;/07_csf_holdout_validation&lt;/font&gt;&lt;br&gt;&lt;b&gt;先看&lt;/b&gt;：artifact_catalog → csf_holdout_gate_decision → csf_holdout_run_manifest → holdout_test_compare&lt;br&gt;&lt;b&gt;生成&lt;/b&gt;：csf_holdout_run_manifest.json、holdout_factor_diagnostics.parquet、holdout_test_compare.parquet、holdout_portfolio_compare.parquet、rolling_holdout_stability.json、regime_shift_audit.json、csf_holdout_gate_decision.md、artifact_catalog.md、field_dictionary.md&lt;br&gt;&lt;b&gt;用途&lt;/b&gt;：验证冻结后的 CSF 方案在最终 holdout 里是否稳健，并给出最终 review 输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="840" y="910" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="closure-note-csf" value="&lt;b&gt;每阶段共同 review 输出&lt;/b&gt;&lt;br&gt;review/request：adversarial_review_request.yaml、spawned_reviewer_receipt.yaml&lt;br&gt;review/result：adversarial_review_result.yaml、review_findings.yaml&lt;br&gt;review/closure：latest_review_pack.yaml、stage_gate_review.yaml、stage_completion_certificate.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1640" y="330" width="720" height="180" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
