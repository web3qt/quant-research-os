      "updated": 1776001000000,
      "link": null,
      "locked": false,
      "text": "举个例子：Data Ready 到底准备什么数据",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "举个例子：Data Ready 到底准备什么数据",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    },
    {
      "id": "example-box",
      "type": "rectangle",
      "x": 40,
