      "hasTextLink": false
    },
    {
      "id": "not-data-ready-body",
      "type": "text",
      "x": 60,
      "y": 2004,
      "width": 778,
      "height": 46,
      "angle": 0,
      "strokeColor": "#7f1d1d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ac2",
      "roundness": null,
      "seed": 1063,
      "version": 1,
      "versionNonce": 2063,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776001000000,
      "link": null,
      "locked": false,
      "text": "不是在定义正式因子，不是在算 factor score，不是在做 train 统计尺子，也不是在决定做多做空谁。\n它是在准备“后面所有因子都必须共享”的研究底座。",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "不是在定义正式因子，不是在算 factor score，不是在做 train 统计尺子，也不是在决定做多做空谁。\n它是在准备“后面所有因子都必须共享”的研究底座。",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    }
  ],
