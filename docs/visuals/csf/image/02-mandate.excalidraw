    },
    {
      "id": "data-body",
      "type": "text",
      "x": 520,
      "y": 772,
      "width": 356,
      "height": 180,
      "angle": 0,
      "strokeColor": "#115e59",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "e7",
      "roundness": null,
      "seed": 810314,
      "version": 1,
      "versionNonce": 810315,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775812546677,
      "link": null,
      "locked": false,
      "text": "data_source: 上游原始数据从哪里来，后续阶段必须复用同一来源。\nbar_size: 全链路基础 bar 粒度，这里定 1m 就不能后面悄悄换 5m。\nholding_horizons: 允许预测的 forward 窗口，如 5m / 15m。\ntrain: 训练窗，只能用来拟合和定阈值。\ntest: 测试窗，用来做独立样本检验，不能回写 train 规则。\nbacktest: 回测窗，用来做组合表达和容量评估。\nholdout: 留出窗，最后的 out-of-sample 检验，不反哺前面设计。\nlabel_time_semantics: 标签时间语义，定义 t0 和未来收益从哪里开始算。\nno_lookahead_guardrail: 反前视护栏，t0 之后信息只能做标签，不能进特征。\n\n输出锚点：time_split.json + mandate.md",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "data_source: 上游原始数据从哪里来，后续阶段必须复用同一来源。\nbar_size: 全链路基础 bar 粒度，这里定 1m 就不能后面悄悄换 5m。\nholding_horizons: 允许预测的 forward 窗口，如 5m / 15m。\ntrain: 训练窗，只能用来拟合和定阈值。\ntest: 测试窗，用来做独立样本检验，不能回写 train 规则。\nbacktest: 回测窗，用来做组合表达和容量评估。\nholdout: 留出窗，最后的 out-of-sample 检验，不反哺前面设计。\nlabel_time_semantics: 标签时间语义，定义 t0 和未来收益从哪里开始算。\nno_lookahead_guardrail: 反前视护栏，t0 之后信息只能做标签，不能进特征。\n\n输出锚点：time_split.json + mandate.md",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    },
