    },
    {
      "id": "route-body",
      "type": "text",
      "x": 60,
      "y": 772,
      "width": 535.3433837890625,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "e4",
      "roundness": null,
      "seed": 810308,
      "version": 2,
      "versionNonce": 434051082,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775813668858,
      "link": null,
      "locked": false,
      "text": "research_route: 研究范式，决定这条线走截面排序还是别的证据体系。\nfactor_role: 因子在策略里的职责，是 standalone alpha、regime_filter 还是 combo_filter。\nfactor_structure: 因子的结构身份，单因子还是多因子分数。\nportfolio_expression: 最终组合怎么表达。standalone_alpha 可用 long_short_market_neutral / long_only_rank / short_only_rank / benchmark_relative_long_only / group_relative_long_short；regime_filter 只允许 target_strategy_filter；combo_filter 允许 target_strategy_filter / target_strategy_overlay。\nneutralization_policy: 去掉哪些共性暴露，如 market beta 或 group 暴露。\ntarget_strategy_reference: 若不是 standalone alpha，说明它服务哪条目标策略。\ngroup_taxonomy_reference: 若做 group neutral，后续分组和 bucket 分析共用哪版 taxonomy。\nexcluded_routes: 明确不走哪些路线，防止失败后静默切换叙事。\n\n输出锚点：research_route.yaml",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "research_route: 研究范式，决定这条线走截面排序还是别的证据体系。\nfactor_role: 因子在策略里的职责，是 standalone alpha、regime_filter 还是 combo_filter。\nfactor_structure: 因子的结构身份，单因子还是多因子分数。\nportfolio_expression: 最终组合怎么表达。standalone_alpha 可用 long_short_market_neutral / long_only_rank / short_only_rank / benchmark_relative_long_only / group_relative_long_short；regime_filter 只允许 target_strategy_filter；combo_filter 允许 target_strategy_filter / target_strategy_overlay。\nneutralization_policy: 去掉哪些共性暴露，如 market beta 或 group 暴露。\ntarget_strategy_reference: 若不是 standalone alpha，说明它服务哪条目标策略。\ngroup_taxonomy_reference: 若做 group neutral，后续分组和 bucket 分析共用哪版 taxonomy。\nexcluded_routes: 明确不走哪些路线，防止失败后静默切换叙事。\n\n输出锚点：research_route.yaml",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    },
