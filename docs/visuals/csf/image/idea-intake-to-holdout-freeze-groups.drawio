                    <mxGeometry x="450" y="490" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_diagnostic_note" value="required_diagnostics：必须生成的诊断项清单&lt;br&gt;after_cost_rule：formal gate 是否按净成本结果判定&lt;br&gt;name_level_rule：单名字主导时如何处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
