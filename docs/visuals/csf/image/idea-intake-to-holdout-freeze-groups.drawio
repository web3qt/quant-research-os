                    <mxGeometry x="20" y="120" width="220" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_what" value="1.是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
