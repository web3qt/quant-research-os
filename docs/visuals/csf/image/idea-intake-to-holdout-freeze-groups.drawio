                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="chv_label" value="csf_holdout_validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#F59E0B;fontColor=#B45309;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="20" y="120" width="250" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="chv_what" value="1.是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="20" width="170" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="chv_definition" value="把 csf_backtest_ready 已冻结的组合方案&#xa;拿到最终 untouched holdout window 上验证；这里只能解释验证结果、drift 和失败治理，&#xa;不能回写 factor、variant 或组合参数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="18" width="840" height="82" as="geometry"/>
