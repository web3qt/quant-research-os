                    <mxGeometry x="1500" y="460" width="390" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_note_holdout" value="holdout 将只消费这里冻结好的 portfolio contract / 权重输出 /&#xa;成本与容量口径，不应再发明另一套组合规则" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
