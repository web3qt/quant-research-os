                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_process_to_rebalance" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_process" target="ctf_rebalance_contract" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_process_to_delivery" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_process" target="ctf_delivery_contract" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_preprocess_to_note" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_preprocess_contract" target="ctf_preprocess_note" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
