                <mxCell id="cbr_portfolio_contract" value="portfolio_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="130" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_portfolio_note" value="portfolio_expression：正式组合表达或 target strategy 消费方式&lt;br&gt;selection_rule：从排序结果映射成持仓的规则&lt;br&gt;weight_mapping_rule：score 如何映射成权重&lt;br&gt;gross_exposure_rule：总敞口约束" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="115" width="680" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_execution_contract" value="execution_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="250" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_execution_note" value="rebalance_execution_lag：调仓信号与执行之间的 lag&lt;br&gt;turnover_budget_rule：换手预算规则&lt;br&gt;cost_model：正式成本模型&lt;br&gt;capacity_model：正式容量模型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="235" width="620" height="98" as="geometry"/>
