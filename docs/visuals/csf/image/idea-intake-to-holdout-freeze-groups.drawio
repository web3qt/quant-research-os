                    <mxGeometry x="450" y="370" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="chv_stability_note" value="direction_flip_rule：方向翻转何时升级处理&lt;br&gt;coverage_rule：覆盖塌缩时如何处理&lt;br&gt;regime_shift_rule：regime shift 如何审计与解释" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="355" width="620" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="chv_failure_governance" value="failure_governance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="485" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="chv_failure_note" value="retryable_conditions：哪些失败可重跑&lt;br&gt;child_lineage_trigger：哪些情况必须开 child lineage&lt;br&gt;rollback_boundary：当前线最多能回改到哪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="470" width="620" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="chv_delivery_contract" value="delivery_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="600" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="chv_delivery_note" value="machine_artifacts：holdout_run_manifest、holdout_factor_diagnostics、holdout_test_compare、holdout_portfolio_compare、rolling_holdout_stability、regime_shift_audit、holdout_gate_decision 等正式交付物&lt;br&gt;consumer_stage：当前固定是 terminal&lt;br&gt;field_doc_rule：每个机器文件都必须带 companion field doc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="585" width="860" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="chv_note_not_extension" value="holdout 不是 backtest 延长段；它验证的是最终 untouched window，&#xa;不能把 holdout 与 backtest 合并成一条绩效曲线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="180" width="390" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="chv_note_forbidden_changes" value="holdout 禁止改参数、改 factor 选择、改组合规则或重估任何上游尺子；&#xa;只能复用已冻结 inputs 并解释结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="320" width="390" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="chv_note_drift" value="direction flip、coverage collapse、regime shift 都必须有显式解释；&#xa;rolling OOS 一致性差时，最高只能 CONDITIONAL PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="460" width="390" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="chv_note_child_lineage" value="holdout 失败后不能一路偷偷改回 signal/train；&#xa;需要按 failure governance 明确走 retry、rollback 或 child lineage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
