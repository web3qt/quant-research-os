    <diagram id="csf-holdout-validation-contracts" name="csf_holdout_validation">
        <mxGraphModel dx="1273" dy="521" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2500" pageHeight="2500" background="#FBF7E6" math="0" shadow="0">
