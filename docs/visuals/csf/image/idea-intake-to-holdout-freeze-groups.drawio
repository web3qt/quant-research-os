                    <mxGeometry x="450" y="370" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_risk_note" value="max_name_weight_rule：单名字权重上限&lt;br&gt;net_exposure_rule：净敞口边界&lt;br&gt;group_neutral_overlay：若启用 group-neutral 的 overlay 引用&lt;br&gt;target_strategy_reference：是否对照目标策略" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="355" width="660" height="108" as="geometry"/>
