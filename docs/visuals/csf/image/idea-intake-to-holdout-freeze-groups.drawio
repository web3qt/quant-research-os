    <diagram id="csf-test-evidence-contracts" name="csf_test_evidence">
        <mxGraphModel dx="1273" dy="521" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2500" pageHeight="2500" background="#FBF7E6" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="cte_label" value="csf_test_evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#F59E0B;fontColor=#B45309;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="20" y="120" width="210" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="cte_what" value="1.是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="20" width="170" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="cte_definition" value="把 csf_train_freeze 已冻结的 train 尺子&#xa;拿到独立样本上做正式证据确认，并冻结可进入 backtest 的&#xa;selected variants / frozen spec；这里是证据层，不是交易层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="18" width="840" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="cte_process" value="2.冻结物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="145" width="170" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="cte_window_contract" value="window_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="130" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cte_window_note" value="test_window_source：正式 test 窗来源&lt;br&gt;train_reuse_note：test 如何复用 train 规则&lt;br&gt;subperiod_rule：子区间稳定性怎么检查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="115" width="620" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="cte_variant_contract" value="variant_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="235" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cte_variant_note" value="selected_variant_ids：test 正式评估的变体 ID&lt;br&gt;selection_rule：哪些对象能进入正式 gate&lt;br&gt;multiple_testing_note：禁止 test 再扩搜索，必须保留全量 ledger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="220" width="660" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="cte_evidence_contract" value="evidence_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="355" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cte_evidence_note" value="primary_evidence_contract：正式主证据类型&lt;br&gt;factor_role：standalone_alpha 或 regime_filter / combo_filter&lt;br&gt;role_specific_note：当前角色的专属 gate 边界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="340" width="620" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="cte_audit_contract" value="audit_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="475" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cte_audit_note" value="breadth_rule：覆盖宽度要求&lt;br&gt;flip_rule：方向翻转何时升级处理&lt;br&gt;coverage_note：coverage 失败是 blocking，不是只做说明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="460" width="620" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="cte_delivery_contract" value="delivery_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="590" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cte_delivery_note" value="machine_artifacts：test 统计、admissibility、factor_selection、selected_factor_spec、test_gate_table 等正式交付物&lt;br&gt;consumer_stage：下游固定是 csf_backtest_ready&lt;br&gt;frozen_spec_note：backtest 只能消费 test-admitted variants / frozen spec" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="575" width="700" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="cte_note_role_split" value="standalone_alpha 与 regime_filter / combo_filter&#xa;证据语义必须分流；不能拿同一套 gate 硬套" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="180" width="360" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="cte_note_formal_gate" value="formal gate 看的是独立样本证据：&#xa;standalone_alpha 看 Rank IC / bucket spread / monotonicity；&#xa;filter/combo 看 gated vs ungated 改善，不看 backtest PnL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="305" width="390" height="126" as="geometry"/>
                </mxCell>
                <mxCell id="cte_note_admissibility" value="admissibility 锁定谁能进入 backtest，&#xa;但不等于“交易层已经胜利”；不能把 test 直接写成 backtest ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="470" width="390" height="106" as="geometry"/>
                </mxCell>
                <mxCell id="cte_note_guardrails" value="不得新增未冻结 variant，不得在 test 重估 train 尺子，&#xa;不得只保留通过者；multiple testing 与 coverage 痕迹都必须保留" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
