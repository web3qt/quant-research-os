                <mxCell id="chv_process" value="2.冻结物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="145" width="170" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="chv_window_contract" value="window_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="130" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="chv_window_note" value="holdout_window_source：正式 untouched holdout source&lt;br&gt;reuse_rule：holdout 只能复用哪些上游合同&lt;br&gt;drift_scope：holdout 与哪些 prior windows 做对比" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="115" width="660" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="chv_reuse_contract" value="reuse_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="245" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="chv_reuse_note" value="backtest_contract_source：复用哪一版 portfolio contract&lt;br&gt;test_contract_source：复用哪一版 test 准入来源&lt;br&gt;variant_reuse_rule：holdout 是否允许改 selected variants&lt;br&gt;no_reestimate_rule：holdout 是否允许重估任何参数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
