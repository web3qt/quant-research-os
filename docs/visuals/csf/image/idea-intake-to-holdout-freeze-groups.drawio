                    <mxGeometry x="450" y="605" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_delivery_note" value="machine_artifacts：portfolio_contract.yaml、portfolio_weight_panel.parquet、rebalance_ledger.csv、turnover_capacity_report.parquet、cost_assumption_report.md、portfolio_summary.parquet、name_level_metrics.parquet、drawdown_report.json、csf_backtest_gate_table.csv 等&lt;br&gt;consumer_stage：下游固定是 csf_holdout_validation&lt;br&gt;frozen_config_note：holdout 只能复用这套组合合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="590" width="860" height="128" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_note_expression" value="portfolio_expression 必须显式继承上游冻结语义：&#xa;独立组合、target_strategy_filter、target_strategy_overlay 不能混写" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="180" width="390" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_note_no_reselect" value="backtest 不得重新选择 factor，也不得重估 train 尺子；&#xa;这里只把 test-admitted variants 映射成正式组合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
