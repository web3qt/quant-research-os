                <mxCell id="cbr_definition" value="把 csf_test_evidence 已准入的 factor / variant&#xa;映射成正式组合合同、执行口径、风险边界和诊断要求；&#xa;这里冻结的是组合表达与净成本后可行性，不是重写上游因子结论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="18" width="860" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="cbr_process" value="2.冻结物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
