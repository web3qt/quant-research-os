                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_rebalance_to_note" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_rebalance_contract" target="ctf_rebalance_note" edge="1">
