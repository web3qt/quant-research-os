                <mxCell id="csr_definition" value="把 `02_csf_data_ready` 的截面底座&#xa;正式冻结成因子合同，让后面的 train / test / backtest 都只能复用这一版因子身份与角色语义" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="18" width="700" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="csr_process" value="2.冻结物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="145" width="170" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="csr_process_hint" value="左边是 freeze group，右边是这组在冻结什么。&#xa;这页不是流程图，所以不再用箭头强调顺序。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontSize=13;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="210" y="230" width="170" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_identity" value="factor_identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="145" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_identity_note" value="factor_id：正式因子身份 ID&lt;br&gt;factor_version：lineage 内版本号&lt;br&gt;factor_direction：因子方向解释(高分是好是坏)&lt;br&gt;factor_structure：single_factor 或多组件结构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="410" y="230" width="420" height="138" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_role_contract" value="factor_role_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="930" y="145" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_role_contract_note" value="这组在冻结“它扮演什么角色”。&lt;br&gt;factor_role：standalone_alpha / regime_filter / combo_filter&lt;br&gt;portfolio_expression：这个角色允许消费的正式组合表达" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="890" y="230" width="420" height="138" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_structure_contract" value="factor_structure_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="470" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_structure_contract_note" value="这组在冻结“它是什么结构”。&lt;br&gt;factor_structure：single_factor 或 multi_factor_score&lt;br&gt;如果是多因子，这里要把组合方式定成确定性的，不留到 train 再学权重" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="410" y="555" width="420" height="158" as="geometry"/>
                </mxCell>
                <mxCell id="csr_neutralization_policy" value="neutralization_policy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="930" y="470" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_neutralization_policy_note" value="这组在冻结“后面如何处理中性化语义”。&lt;br&gt;neutralization_policy：none / market_beta_neutral / group_neutral&lt;br&gt;若启用 group_neutral，这里必须带出 taxonomy 版本依赖" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="890" y="555" width="420" height="158" as="geometry"/>
                </mxCell>
                <mxCell id="csr_delivery_contract" value="delivery_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="690" y="820" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_delivery_note" value="这组在冻结“下游到底能拿走什么”。&lt;br&gt;正式产物至少包括 factor_panel / factor_manifest / factor_coverage&lt;br&gt;consumer_stage：锁定下游为 csf_train_freeze，防止 train 偷改因子合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="600" y="905" width="420" height="138" as="geometry"/>
                </mxCell>
                <mxCell id="csr_note_mask_boundary" value="coverage / missing / eligibility&#xa;要分层，不要混写" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="230" width="320" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="csr_note_real_groups" value="这页按真实 freeze groups 画。&#xa;目的不是列全字段，而是让读者一眼看出：skill 实际是怎么分组确认的" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="380" width="320" height="88" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="csf-train-freeze-contracts" name="csf_train_freeze">
        <mxGraphModel dx="3773" dy="433" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2500" pageHeight="2500" background="#FBF7E6" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="ctf_label" value="csf_train_freeze" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#F59E0B;fontColor=#B45309;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="-2" y="85" width="210" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_what" value="1.是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="20" width="170" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_definition" value="把 csf_signal_ready 已冻结的 factor contract&#xa;进一步收敛成 train 期必须复用的 preprocess / neutralization /&#xa;ranking bucket / rebalance 尺子，并明确 signal 后不可再动的 axis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="18" width="840" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_process" value="2.冻结物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D75D8;fontColor=#1D4ED8;fontStyle=1;fontSize=16;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="220" y="145" width="170" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_preprocess_contract" value="preprocess_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="130" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_preprocess_note" value="winsorize_policy：正式截尾/截断规则&lt;br&gt;standardize_policy：按什么截面标准化&lt;br&gt;missing_fill_policy：因子缺失值如何处理&lt;br&gt;coverage_floor_rule：低 coverage 截面怎么处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="115" width="620" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_neutralization_contract" value="neutralization_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="245" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_neutralization_note" value="neutralization_policy：正式中性化策略&lt;br&gt;beta_estimation_window：若做 beta 中性化的估计窗&lt;br&gt;group_taxonomy_reference：group-neutral 依赖的 taxonomy 版本&lt;br&gt;residualization_formula：残差口径公式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="230" width="620" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_ranking_bucket_contract" value="ranking_bucket_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="365" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_ranking_bucket_note" value="ranking_scope：在什么范围内做截面排序&lt;br&gt;bucket_schema：分桶方式，例如 quintile / decile&lt;br&gt;quantile_count：正式桶数&lt;br&gt;min_names_per_bucket：每桶最少名字数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="350" width="620" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_rebalance_contract" value="rebalance_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="485" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_rebalance_note" value="rebalance_frequency：多久调仓一次&lt;br&gt;signal_lag_rule：score freeze 后多久才允许交易&lt;br&gt;holding_period_rule：每次持有多久&lt;br&gt;overlap_policy：相邻持仓是否允许重叠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="470" width="620" height="98" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_delivery_contract" value="delivery_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8A3;strokeColor=#F59E0B;fontColor=#D97706;fontStyle=1;fontSize=15;fontFamily=Comic Sans MS;" parent="1" vertex="1">
                    <mxGeometry x="450" y="605" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_delivery_note" value="machine_artifacts：正式交付 csf_train_freeze.yaml、train_quality.parquet、train_variant_ledger.csv、train_rejects.csv&lt;br&gt;consumer_stage：下游固定是 csf_test_evidence&lt;br&gt;reuse_constraints：test 只能复用 train 尺子，不得重估或偷改 train 规则" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="590" width="700" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_what_to_definition" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_what" target="ctf_definition" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_process_to_preprocess" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_process" target="ctf_preprocess_contract" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ctf_edge_process_to_neutralization" value="" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#F59E0B;" parent="1" source="ctf_process" target="ctf_neutralization_contract" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
