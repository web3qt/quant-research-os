    {
      "id": "review-body",
      "type": "text",
      "x": 60,
      "y": 200,
      "width": 340,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
