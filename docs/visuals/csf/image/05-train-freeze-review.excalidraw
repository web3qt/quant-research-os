      "boundElements": [],
      "updated": 1776002000000,
      "link": null,
      "locked": false,
      "text": "1. winsorize、standardize、missing fill、coverage floor 口径是否冻结\n2. neutralization policy、beta window、taxonomy reference 是否冻结\n3. bucket schema、quantile count、tie-break、min names per bucket 是否冻结\n4. rebalance frequency、signal lag、overlap policy 是否冻结\n5. train_variant_ledger 与 reject ledger 是否齐全且可解释\n6. frozen_signal_contract_reference 与 governable / non-governable axes 是否写清",
      "rawText": "1. winsorize、standardize、missing fill、coverage floor 口径是否冻结\n2. neutralization policy、beta window、taxonomy reference 是否冻结\n3. bucket schema、quantile count、tie-break、min names per bucket 是否冻结\n4. rebalance frequency、signal lag、overlap policy 是否冻结\n5. train_variant_ledger 与 reject ledger 是否齐全且可解释\n6. frozen_signal_contract_reference 与 governable / non-governable axes 是否写清",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. winsorize、standardize、missing fill、coverage floor 口径是否冻结\n2. neutralization policy、beta window、taxonomy reference 是否冻结\n3. bucket schema、quantile count、tie-break、min names per bucket 是否冻结\n4. rebalance frequency、signal lag、overlap policy 是否冻结\n5. train_variant_ledger 与 reject ledger 是否齐全且可解释\n6. frozen_signal_contract_reference 与 governable / non-governable axes 是否写清",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
