                    <mxGeometry x="2580" y="470" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="04 csf_test_evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2860" y="470" width="230" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="05 csf_backtest_ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="3150" y="470" width="240" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="06 csf_holdout_validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="3450" y="470" width="260" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="199" value="&lt;b&gt;01 csf_data_ready 在做什么&lt;/b&gt;&lt;br&gt;它在搭横截面研究底座，不是在写因子。&lt;br&gt;panel key（把主表固定成 date + asset；后续 factor / label / return 都挂在这层）&lt;br&gt;universe membership（把每个时点哪些 symbol 在宇宙里单独物化，后续必须可重建）&lt;br&gt;eligibility base mask（把缺 bar、未上市、不可交易等基础准入条件独立成 mask）&lt;br&gt;shared feature base（先对齐 OHLCV、return、liquidity 等共享字段，供后续因子复用）&lt;br&gt;coverage / missing semantics（区分缺失、坏值、stale、未上市，不能静默吞掉）&lt;br&gt;group taxonomy（若做 group_neutral，先冻结行业 / 板块 / 风格分组映射）&lt;br&gt;formal outputs（panel_manifest、universe_membership、eligibility_mask、coverage_report、shared_feature_base）&lt;br&gt;&lt;br&gt;不是正式因子定义，不做 IC / 分层 / train 统计，不把 eligibility 藏进下游代码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1960" y="570" width="560" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="201" value="&lt;b&gt;02 csf_signal_ready 在做什么&lt;/b&gt;&lt;br&gt;它在把横截面研究语义冻结成正式因子合同，不是在训练。&lt;br&gt;factor identity（冻结 factor_id、factor_version、factor_direction，说明这条因子是谁、方向是什么）&lt;br&gt;panel contract（把因子主表固定成 date + asset，并冻结 as_of_semantics，保证同一时点不同资产可横向比较）&lt;br&gt;factor expression（冻结 raw_factor_fields、derived_factor_fields、final_score_field，说明 score 怎么算出来）&lt;br&gt;coverage / eligibility semantics（把 coverage、missing、eligibility 传递规则写清，不能混进下游训练）&lt;br&gt;context contract（若做多因子、组内排序或 group_neutral，冻结组合公式和 group context）&lt;br&gt;formal outputs（factor_panel、factor_manifest、factor_coverage_report、factor_contract、field_dictionary）&lt;br&gt;&lt;br&gt;不是 train 阶段，不学权重，不看 test/backtest 回写 signal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="2550" y="570" width="560" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="203" value="&lt;b&gt;04 csf_test_evidence 在做什么&lt;/b&gt;&lt;br&gt;它在验证冻结后的截面排序能力，或 filter / combo 条件改善能力，是否在独立样本里仍然成立。&lt;br&gt;reuse frozen train rules（只复用 train 已冻结的 preprocess、neutralization、bucket、rebalance 规则）&lt;br&gt;independent-sample evidence（standalone_alpha 看 Rank IC、bucket spread、monotonicity、breadth、subperiod stability；filter / combo 看 gated vs ungated 改善）&lt;br&gt;admissible set（冻结 test white list / admissible variants，而不是现场选冠军）&lt;br&gt;full test ledger（保留全量 variant 证据，不只留下通过者）&lt;br&gt;formal outputs（csf_test_gate_table、selected_variants_test、rank_ic 或 gated compare 证据）&lt;br&gt;&lt;br&gt;不重估 train 尺子，不新增未冻结 variant，不看 backtest 再回写 test 结论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1960" y="860" width="540" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="204" value="&lt;b&gt;05 csf_backtest_ready 在做什么&lt;/b&gt;&lt;br&gt;它在把冻结后的因子分数映射成正式组合，并验证净成本后的经济可行性。&lt;br&gt;portfolio expression（冻结 long_short_market_neutral 或 long_only_rank 等正式组合表达）&lt;br&gt;weight mapping rule（把 score 如何映射成选股、权重、再平衡和执行 lag 机器可读冻结）&lt;br&gt;cost / capacity contract（冻结成本模型、换手预算、容量和参与率分析口径）&lt;br&gt;portfolio feasibility evidence（看成本后收益、drawdown、集中度、name-level metrics）&lt;br&gt;formal outputs（portfolio_contract、weight_panel、rebalance_ledger、capacity_report、portfolio_summary）&lt;br&gt;&lt;br&gt;不在 backtest 重新挑 variant，不改 long/short cut 或权重规则，不只报 gross 不报净成本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="2550" y="860" width="540" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="205" value="&lt;b&gt;06 csf_holdout_validation 在做什么&lt;/b&gt;&lt;br&gt;它在验证最终冻结方案，在最后完全未参与设计的窗口里是否仍然没有翻向或塌陷。&lt;br&gt;reuse frozen plan（只复用 test / backtest 冻结方案，不再重估任何上游尺子）&lt;br&gt;holdout vs prior compare（比较 holdout 与 test / backtest 的因子和组合表现）&lt;br&gt;stability audit（检查 rolling holdout stability、breadth / coverage 是否塌陷）&lt;br&gt;regime shift audit（当分布漂移明显时，显式审计是 regime 变化还是机制断裂）&lt;br&gt;formal outputs（holdout diagnostics、test compare、portfolio compare、regime_shift_audit）&lt;br&gt;&lt;br&gt;不在 holdout 调参，不改 bucket cut / neutralization / weight mapping，不把 holdout 并回 test 或 backtest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="3140" y="860" width="540" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="当前单入口编排&#xa;到 holdout_validation review 停止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECC8;strokeColor=#D97706;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="3680" y="290" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="19" value="07+ 后续治理阶段&#xa;promotion / shadow / canary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#64748B;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="3680" y="410" width="230" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="SOP 已定义&#xa;未纳入当前 qros-research-session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#64748B;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="3680" y="530" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="209" value="&lt;b&gt;为什么这里不再作为当前主线&lt;/b&gt;&lt;br&gt;当前 qros-research-session first-wave 只覆盖到 holdout_validation review。&lt;br&gt;也就是说，runtime 在当前版本不会自动从研究阶段继续推进到 07+ 治理阶段。&lt;br&gt;&lt;br&gt;因此右侧这块应被理解为 roadmap / governance blueprint，而不是当前已落地的单入口编排路径。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="3700" y="660" width="280" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="210" value="&lt;b&gt;07+ 后续治理阶段仍然重要&lt;/b&gt;&lt;br&gt;SOP 里已经定义了 promotion_decision、shadow_admission、canary_production 这些治理节点。&lt;br&gt;它们不是研究阶段的普通延长线，而是组织级 GO、监控、回滚、owner 与运行边界的治理合同。&lt;br&gt;&lt;br&gt;如果未来接入 runtime，应明确以治理 gate 的身份接入，而不是假装它们已经和研究主线打通。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="3700" y="880" width="280" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="211" value="&lt;b&gt;当前图里的阅读方式&lt;/b&gt;&lt;br&gt;左侧案例块是 CSF 示例，不代表系统默认只推荐这条 route。&lt;br&gt;中间两条链路表示当前已落地、可由 qros-research-session 编排的 first-wave 研究主线。&lt;br&gt;右侧灰色区域表示未来治理阶段，已在 SOP 定义，但不应被当成今天已经接入的 runtime 事实。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="3700" y="1115" width="280" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="67" value="research_question&#xa;这条研究线到底要回答什么问题&#xa;定义研究对象与研究目标" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="820" width="460" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="68" value="hypothesis pair&#xa;primary_hypothesis: 主机制解释是什么&#xa;counter_hypothesis: 最强反方解释是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1500" y="960" width="460" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="69" value="route rationale&lt;br&gt;research_route: 该走哪条研究流程（时间序列研究，还是横截面因子研究）&lt;br&gt;excluded_routes: 为什么不是另一条&lt;br&gt;route_rationale: 路线判断依据是什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="1020" width="460" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="70" value="factor identity&#xa;factor_role（决定它是独立 alpha，还是给别的策略做过滤）&#xa;factor_structure（决定研究一条因子，还是多条因子合成分数）&#xa;portfolio_expression（决定最后用什么组合方式表达这条因子）&#xa;neutralization_policy（决定是否先去掉共同暴露，再看剩余 alpha）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1540" y="1120" width="460" height="148" as="geometry"/>
                </mxCell>
                <mxCell id="71" value="success / failure criteria&#xa;什么证据算成功&#xa;什么情况算失败&#xa;避免结果出来后再改标准" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="1250" width="460" height="100" as="geometry"/>
                </mxCell>
