    <diagram id="qros-flow" name="Flow">
        <mxGraphModel dx="1321" dy="357" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4000" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="QROS 当前已落地主流程 + CSF 示例图&#xa;Current Runtime Boundary And CSF Example" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
                    <mxGeometry x="1550" y="40" width="470" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="44" value="Idea Intake 案例提问区（示例）&#xa;先问清问题，再决定能不能进入 mandate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="150" width="520" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="1. recommended_route: cross_sectional_factor&#xa;为什么问：先冻结研究语义，决定 mandate 之后进入哪条 stage contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="250" width="520" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="46" value="2. market / data_source / bar_size&#xa;market: binance futures_um&#xa;data_source: /Users/mac08/workspace/coin-data/binance/futures_um&#xa;bar_size: 1m&#xa;为什么问：先固定数据口径、时间粒度和可研究样本基座" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="354" width="520" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="47" value="3. universe&#xa;事件时点在 1m 面板中有有效 bar 的全部非 BTC 符号&#xa;BTCUSDT 只作为事件锚&#xa;为什么问：保证候选集机械化定义，避免事后挑币" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="492" width="520" height="102" as="geometry"/>
                </mxCell>
                <mxCell id="48" value="4. target_task&#xa;BTCUSDT 出现 1m downside shock 后&#xa;下一根 1m K 开始做空横截面最脆弱 ALT&#xa;持有 3m-5m&#xa;为什么问：先定义 target_task 的时间语义和 horizon 范围，避免把不同研究问题混成一个" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="614" width="520" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="49" value="5. hypothesis pair&#xa;primary: BTC shock 会暴露可排序的 ALT 脆弱度因子&#xa;counter: 后续弱势只是共同 beta，同步释放后无横截面 alpha&#xa;为什么问：防止只讲单边故事，明确真正要证伪什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="750" width="520" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="50" value="6. kill_criteria&#xa;事件定义若不能实时化、排序若依赖未来信息、universe 若不能机械化、若只能解释成共同 beta&#xa;为什么问：先写清哪些前提不成立就不应继续进入 mandate；这不是结果止损，而是研究资格止损" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="886" width="520" height="106" as="geometry"/>
                </mxCell>
                <mxCell id="51" value="这些问题被问清后&#xa;才可能通过 intake gate 并进入 mandate_confirmation_pending" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="160" y="1020" width="280" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="00 idea_intake&#xa;判断这个想法值不值得正式研究" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="630" y="280" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="mandate_confirmation_pending&#xa;intake 已通过，等待显式 mandate freeze 授权" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="980" y="270" width="320" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="55" value="research_intent&lt;br&gt;scope_contract&lt;br&gt;data_contract&lt;br&gt;execution_contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=13;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="990" y="430" width="300" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="59" value="research_intent&#xa;先冻结研究主问题、对立解释、route、CSF 身份&#xa;以及 success / failure criteria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="930" y="570" width="300" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="60" value="scope_contract&#xa;market（在哪个市场研究）&#xa;universe（哪些标的算候选集）&#xa;target_task（到底在研究什么任务）&#xa;excluded_scope（哪些明确不做）&#xa;budget_days / max_iterations（最多花几天、允许试几轮）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="570" width="300" height="124" as="geometry"/>
                </mxCell>
                <mxCell id="61" value="data_contract&#xa;data_source（数据从哪里来）&#xa;bar_size（基础时间粒度是什么）&#xa;holding_horizons（评估哪些持有窗口）&#xa;timestamp_semantics（何时确认事件、何时打分、何时入场）&#xa;no_lookahead_guardrail（只能使用事件时点可见信息）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="930" y="700" width="300" height="112" as="geometry"/>
                </mxCell>
                <mxCell id="62" value="execution_contract&#xa;time_split（train / test / backtest / holdout 怎么切）&#xa;参数边界（哪些参数允许调、范围到哪里）&#xa;artifact contract（每个阶段必须交哪些正式产物）&#xa;capacity / crowding benchmark（后面按什么口径审计容量和拥挤）&#xa;实现栈（用什么运行配置和实现方式落地）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="700" width="300" height="116" as="geometry"/>
