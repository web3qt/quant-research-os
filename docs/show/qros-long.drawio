                    <mxGeometry x="1450" y="810" width="24" height="560" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="每个阶段都必须有&#xa;freeze + lineage-local program + artifacts + review closure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;fontStyle=1;" parent="1" vertex="1">
