    {
      "id": "review-body",
      "type": "text",
      "x": 540,
      "y": 194,
      "width": 320,
      "height": 144,
      "angle": 0,
      "strokeColor": "#115e59",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
