                <mxCell id="csr_factor_identity_note" value="factor_id：正式因子身份 ID&lt;br&gt;factor_version：lineage 内版本号&lt;br&gt;factor_direction：因子方向解释&lt;br&gt;factor_structure：single_factor 或多组件结构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
