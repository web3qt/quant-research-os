                </mxCell>
                <mxCell id="csr_panel_contract_note" value="panel_primary_key：factor panel 主键&lt;br&gt;as_of_semantics：截面值何时冻结可见&lt;br&gt;coverage_contract：每个截面的最低 coverage 要求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
