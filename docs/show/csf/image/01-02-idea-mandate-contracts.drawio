                    <mxGeometry x="450" y="500" width="220" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="csr_factor_expression_note" value="raw_factor_fields：直接依赖的原始字段&lt;br&gt;derived_factor_fields：中间派生字段&lt;br&gt;final_score_field：正式排序分数字段&lt;br&gt;missing_value_policy：因子层缺失处理规则" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F59E0B;fontColor=#9A3412;fontSize=14;fontFamily=Comic Sans MS;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
