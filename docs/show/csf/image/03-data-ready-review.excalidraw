      "lineHeight": 1.25,
      "hasTextLink": false
    },
    {
      "id": "review-body",
      "type": "text",
      "x": 60,
      "y": 200,
      "width": 340,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 3006,
      "version": 1,
      "versionNonce": 4006,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776002000000,
      "link": null,
      "locked": false,
      "text": "1. panel 主键是否明确为 date × asset\n2. universe membership 是否按日期显式记录且可重建\n3. eligibility_base_mask 是否作为独立底座存在\n4. coverage、缺失语义、shared features 是否写清\n5. group_neutral 场景下 taxonomy 是否已冻结或版本化\n6. run_manifest、stage-local rebuild 程序、replay 命令是否齐全",
      "rawText": "1. panel 主键是否明确为 date × asset\n2. universe membership 是否按日期显式记录且可重建\n3. eligibility_base_mask 是否作为独立底座存在\n4. coverage、缺失语义、shared features 是否写清\n5. group_neutral 场景下 taxonomy 是否已冻结或版本化\n6. run_manifest、stage-local rebuild 程序、replay 命令是否齐全",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. panel 主键是否明确为 date × asset\n2. universe membership 是否按日期显式记录且可重建\n3. eligibility_base_mask 是否作为独立底座存在\n4. coverage、缺失语义、shared features 是否写清\n5. group_neutral 场景下 taxonomy 是否已冻结或版本化\n6. run_manifest、stage-local rebuild 程序、replay 命令是否齐全",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    },
