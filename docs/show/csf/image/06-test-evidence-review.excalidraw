    },
    {
      "id": "review-body",
      "type": "text",
      "x": 60,
      "y": 200,
      "width": 340,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 3006,
      "version": 1,
      "versionNonce": 4006,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776002000000,
      "link": null,
      "locked": false,
      "text": "1. test 是否只复用 train freeze 的 frozen rules\n2. standalone_alpha 与 filter/combo 的证据语义是否分流\n3. Rank IC、ICIR、bucket、monotonicity、breadth / 或 gated-vs-ungated 改善 是否齐全\n4. selected / rejected variants 与全量 ledger 是否都保留\n5. selected_factor_spec 是否写清角色、结构、组合表达、中性化\n6. multiple testing 痕迹与 coverage 解释是否都保留",
      "rawText": "1. test 是否只复用 train freeze 的 frozen rules\n2. standalone_alpha 与 filter/combo 的证据语义是否分流\n3. Rank IC、ICIR、bucket、monotonicity、breadth / 或 gated-vs-ungated 改善 是否齐全\n4. selected / rejected variants 与全量 ledger 是否都保留\n5. selected_factor_spec 是否写清角色、结构、组合表达、中性化\n6. multiple testing 痕迹与 coverage 解释是否都保留",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. test 是否只复用 train freeze 的 frozen rules\n2. standalone_alpha 与 filter/combo 的证据语义是否分流\n3. Rank IC、ICIR、bucket、monotonicity、breadth / 或 gated-vs-ungated 改善 是否齐全\n4. selected / rejected variants 与全量 ledger 是否都保留\n5. selected_factor_spec 是否写清角色、结构、组合表达、中性化\n6. multiple testing 痕迹与 coverage 解释是否都保留",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false
    },
