    <diagram id="qros-review-failure-routing" name="Review Failure Routing">
        <mxGraphModel dx="1273" dy="425" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1700" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="rfr-title" value="QROS review 失败分流图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
                    <mxGeometry x="880" y="40" width="560" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-sub" value="这页讲 review verdict 为什么不是普通 debug。&#xa;一旦命中失败类 verdict，正常阶段推进必须立刻停下。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="420" y="150" width="1480" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-start" value="1. 进入 `&lt;stage&gt;_review`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="280" width="260" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-check" value="2. reviewer + runtime 一起看：&#xa;formal gate / required outputs / provenance / closure inputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="940" y="400" width="440" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-decision" value="review verdict" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1050" y="560" width="220" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-pass" value="PASS / CONDITIONAL PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="760" width="320" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-pass2" value="写 review closure：&#xa;`latest_review_pack.yaml`&#xa;`stage_gate_review.yaml`&#xa;`stage_completion_certificate.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="320" y="900" width="540" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-pass3" value="进入 `*_next_stage_confirmation_pending`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="1080" width="380" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-fail" value="PASS FOR RETRY / RETRY / NO-GO / CHILD LINEAGE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1480" y="760" width="520" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-fail2" value="runtime 立刻标记：&#xa;`requires_failure_handling = true`&#xa;`blocking_reason_code = FAILURE_HANDLER_REQUIRED`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="900" width="560" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-fail3" value="切到 `qros-stage-failure-handler`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1540" y="1060" width="400" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-fail4" value="failure handler 决定下一步：&#xa;retry / rollback / child lineage / no-go" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1490" y="1200" width="500" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-note1" value="关键点 1：这些 verdict 不是“再修一修继续 review”，而是治理分流信号。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1320" width="900" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-note2" value="关键点 2：一旦命中失败类 verdict，正常阶段推进必须停下，不能继续写 `*_next_stage_confirmation_pending`。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="1320" width="900" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="rfr-start" target="rfr-check" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="rfr-check" target="rfr-decision" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e3" value="通过" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#16A34A;fontSize=13;" parent="1" source="rfr-decision" target="rfr-pass" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#16A34A;" parent="1" source="rfr-pass" target="rfr-pass2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#16A34A;" parent="1" source="rfr-pass2" target="rfr-pass3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e6" value="失败类 verdict" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;fontSize=13;" parent="1" source="rfr-decision" target="rfr-fail" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;" parent="1" source="rfr-fail" target="rfr-fail2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;" parent="1" source="rfr-fail2" target="rfr-fail3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rfr-e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;" parent="1" source="rfr-fail3" target="rfr-fail4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="qros-csf-route-switch" name="CSF Route Switch">
        <mxGraphModel dx="1273" dy="425" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1700" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="csf-title" value="QROS 路线切换图&#xa;mandate review 之后怎么进 CSF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
                    <mxGeometry x="800" y="40" width="720" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="csf-sub" value="这页讲的不是阶段细节，而是：为什么 mandate review closure 之后，CSF 不能继续默认为 mainline。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="350" y="150" width="1620" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="csf-a" value="1. 先完成：&#xa;idea_intake -&gt; mandate -&gt; mandate review closure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="300" width="420" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="csf-b" value="2. runtime 不会直接跳到 data_ready author。&#xa;必须先进入 next-stage confirmation。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="840" y="300" width="440" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="csf-c" value="3. 看 `01_mandate/author/formal/research_route.yaml`" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="275" width="280" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="csf-main" value="time_series_signal&#xa;进入 mainline：&#xa;`data_ready_confirmation_pending`&#xa;-&gt; `data_ready` -&gt; `signal_ready` -&gt; ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="520" y="560" width="420" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="csf-route" value="cross_sectional_factor&#xa;进入独立 CSF 链：&#xa;`csf_data_ready_confirmation_pending`&#xa;-&gt; `csf_data_ready` -&gt; `csf_signal_ready` -&gt; ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="560" width="460" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="csf-note1" value="关键点 1：CSF 不是 mainline 的一个小变体，而是 mandate 之后切出去的独立链。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="370" y="820" width="700" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="csf-note2" value="关键点 2：如果 `research_route = cross_sectional_factor`，runtime 不应该静默继续默认 `data_ready -&gt; signal_ready`。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1120" y="820" width="840" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="csf-note3" value="关键点 3：切到 CSF 后，grouped freeze 名称也会换成 CSF-specific 版本，例如 `panel_contract`、`factor_identity`、`preprocess_contract`。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="520" y="930" width="960" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="csf-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="csf-a" target="csf-b" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="csf-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="csf-b" target="csf-c" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="csf-e3" value="time_series_signal" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#2563EB;fontSize=13;" parent="1" source="csf-c" target="csf-main" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="csf-e4" value="cross_sectional_factor" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#7C3AED;fontSize=13;" parent="1" source="csf-c" target="csf-route" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="qros-stage-program-hard-gate" name="Stage Program Hard Gate">
        <mxGraphModel dx="1273" dy="425" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="spg-title" value="QROS mandate 之后的硬门&#xa;stage program / provenance / outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
                    <mxGeometry x="760" y="40" width="820" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="spg-sub" value="这页讲 runtime 为什么会卡在 `awaiting_stage_program`、`awaiting_program_validation`、`awaiting_program_execution`。&#xa;适用于 mandate 之后的所有可执行阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="280" y="150" width="1780" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="spg-start" value="freeze approval 已完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1040" y="280" width="260" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d1" value="program dir 存在？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="410" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-miss" value="`awaiting_stage_program`&#xa;`STAGE_PROGRAM_MISSING`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="360" y="430" width="320" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="spg-check1" value="需要：&#xa;`outputs/&lt;lineage&gt;/program/...`&#xa;`stage_program.yaml`&#xa;entrypoint + README.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="320" y="560" width="400" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d2" value="manifest 合法？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="620" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-invalid" value="`awaiting_program_validation`&#xa;`STAGE_PROGRAM_INVALID`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1860" y="640" width="360" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d3" value="执行成功？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="830" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-fail" value="`awaiting_program_execution`&#xa;`PROGRAM_EXECUTION_FAILED`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="360" y="850" width="340" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d4" value="provenance 在吗？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1040" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-prov" value="`PROVENANCE_MISSING`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1860" y="1060" width="300" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="spg-prov2" value="要求：`author/formal/program_execution_manifest.json`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1760" y="1160" width="500" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d5" value="required outputs 有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1250" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="spg-out" value="`OUTPUTS_INVALID`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1270" width="260" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="spg-out2" value="关键提醒：空目录、placeholder、contract-only 文档都不算 outputs 成立" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="220" y="1360" width="540" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="spg-d6" value="review closure 完成？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1460" width="220" height="110" as="geometry"/>
