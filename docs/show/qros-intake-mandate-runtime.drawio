                <mxCell id="spg-review" value="`awaiting_review_closure`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=15;fontStyle=1;" parent="1" vertex="1">
