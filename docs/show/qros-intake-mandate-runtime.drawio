                <mxCell id="spg-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;" parent="1" source="spg-miss" target="spg-check1" edge="1">
