    <diagram id="qros-intake-mandate-runtime" name="Idea Intake Runtime">
        <mxGraphModel dx="1273" dy="425" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="QROS 00 到 01 的 runtime 时序&#xa;idea_intake -&gt; mandate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=24;" parent="1" vertex="1">
                    <mxGeometry x="830" y="30" width="700" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="教学版：只保留关键时序。&#xa;`lineage program` 在 intake 不介入，从 mandate 开始才变成硬门。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="280" y="145" width="1800" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="lane-user" value="User" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#F8FAFC;strokeColor=#94A3B8;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="60" y="260" width="240" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="lane-agent" value="Agent" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#EFF6FF;strokeColor=#2563EB;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="330" y="260" width="280" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="lane-skill" value="Skill" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#ECFDF5;strokeColor=#16A34A;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="640" y="260" width="300" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="lane-runtime" value="Runtime" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#FEF3C7;strokeColor=#D97706;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="970" y="260" width="360" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="lane-outputs" value="outputs/&lt;lineage_id&gt;" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#F5F3FF;strokeColor=#7C3AED;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="1360" y="260" width="560" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="lane-program" value="lineage program" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#FCE7F3;strokeColor=#BE185D;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="1950" y="260" width="520" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="u1" value="1. 提 raw idea&#xa;`qros-research-session ...`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="330" width="200" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="a1" value="命中统一入口，&#xa;调用 `qros-session`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="330" width="240" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="s1" value="规则：brand-new raw idea&#xa;必须先走 `idea_intake`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="660" y="330" width="260" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="r1" value="检测 / 创建 lineage，&#xa;判断当前 stage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="330" width="320" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="o1" value="如果 `00_idea_intake/` 不存在，&#xa;先 scaffold intake 骨架" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="330" width="520" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="p1" value="此时不介入。&#xa;intake 还没有 stage-program 硬门。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1970" y="330" width="480" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="o2" value="初始骨架：&#xa;`idea_brief.md`&#xa;`intake_interview.md`&#xa;`observation_hypothesis_map.md`&#xa;`research_question_set.md`&#xa;`scope_canvas.yaml`&#xa;`qualification_scorecard.yaml`&#xa;`idea_gate_decision.yaml`&#xa;`mandate_freeze_draft.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="455" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="u2" value="2. 回答 interview&#xa;并确认已问清关键问题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="740" width="200" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="a2" value="agent 逐项问 + 回显 summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="720" width="240" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="必须问清：&#xa;observation / hypothesis / route / data / kill criteria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="660" y="710" width="260" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="r2" value="没有 `CONFIRM_IDEA_INTAKE` 之前，&#xa;阶段保持 `idea_intake_confirmation_pending`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="710" width="320" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="a3" value="3. agent 调 `--confirm-intake`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="880" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="r3" value="写 intake approval artifact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="870" width="320" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="o3" value="`00_idea_intake/idea_intake_transition_approval.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="870" width="520" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a4" value="4. 现在才正式补：&#xa;`qualification_scorecard.yaml`&#xa;`idea_gate_decision.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="1010" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="r4" value="如果 verdict 不是 `GO_TO_MANDATE`，&#xa;runtime 仍留在 `idea_intake`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="1010" width="320" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="r5" value="只有 verdict = `GO_TO_MANDATE` 且 route assessment 合法，&#xa;才进入 `mandate_confirmation_pending`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="1140" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="o4" value="此时 outputs 的关键事实是：&#xa;interview 已确认，gate verdict 已写出。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="1080" width="520" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="u3" value="5. 回答 grouped freeze：&#xa;research_intent / scope / data / execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1310" width="200" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="a5" value="agent 继续 mandate bridge 对话" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="1310" width="240" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="`qros-mandate-author` 驱动 4 组 freeze：&#xa;`research_intent` / `scope_contract` / `data_contract` / `execution_contract`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="660" y="1290" width="260" height="114" as="geometry"/>
                </mxCell>
                <mxCell id="o5" value="这时更新的还是桥接草稿：&#xa;`00_idea_intake/mandate_freeze_draft.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="1310" width="520" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="u4" value="6. 用户明确回答：&#xa;`是否确认进入 mandate？` -&gt; 是" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1480" width="200" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="a6" value="agent 调 `--confirm-mandate`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="1480" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="r6" value="写 mandate approval，&#xa;检查所有 freeze group 是否已完成，&#xa;然后进入 `mandate_author`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="1460" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="o6" value="写入：&#xa;`00_idea_intake/mandate_transition_approval.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="1470" width="520" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a7" value="7. agent 触发&#xa;`build_mandate_from_intake()`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="350" y="1620" width="240" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="r7" value="runtime 真正生成 `01_mandate/author/formal/`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="990" y="1620" width="320" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="o7" value="正式产物：&#xa;`mandate.md` / `research_scope.md` / `research_route.yaml` / `time_split.json` / `parameter_grid.yaml` / `run_config.toml` / `artifact_catalog.md` / `field_dictionary.md`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1380" y="1600" width="520" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p2" value="从 `mandate` 开始，`lineage-local stage program` 才是硬门。&#xa;后面阶段会要求 `outputs/&lt;lineage_id&gt;/program/...` + `program_execution_manifest.json`。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1970" y="1600" width="480" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="summary" value="一句话：`idea_intake` 阶段是 agent + skill 主导提问，runtime 负责 scaffold / 状态推进 / gate 检测；&#xa;而 `mandate` 之后，runtime 还会额外要求 stage program / provenance / outputs 的硬门。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEFC;strokeColor=#4A6FA5;fontSize=15;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="350" y="1735" width="2100" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="u1" target="a1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
