    <diagram id="qros-standard-stage-runtime" name="Standard Stage Runtime">
        <mxGraphModel dx="1273" dy="425" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1700" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="sst-title" value="QROS 标准阶段模板时序&#xa;data_ready / signal_ready / train_freeze / test / backtest / holdout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;fontColor=#FFFFFF;strokeColor=#115E59;fontStyle=1;fontSize=22;" parent="1" vertex="1">
                    <mxGeometry x="680" y="30" width="900" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="sst-sub" value="这一页讲 mandate 之后的大多数阶段共用骨架。&#xa;差别主要在 freeze group 和 required outputs，不在时序本身。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="280" y="145" width="1800" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="sst-user" value="User" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#F8FAFC;strokeColor=#94A3B8;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="60" y="260" width="220" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-agent" value="Agent" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#EFF6FF;strokeColor=#2563EB;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="300" y="260" width="260" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-skill" value="Skill" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#ECFDF5;strokeColor=#16A34A;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="580" y="260" width="280" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-runtime" value="Runtime" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#FEF3C7;strokeColor=#D97706;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="880" y="260" width="320" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-outputs" value="outputs / program / review" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#F5F3FF;strokeColor=#7C3AED;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="260" width="620" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-state" value="状态" style="swimlane;whiteSpace=wrap;html=1;horizontal=0;startSize=36;fillColor=#FCE7F3;strokeColor=#BE185D;fontStyle=1;fontSize=17;" parent="1" vertex="1">
                    <mxGeometry x="1860" y="260" width="520" height="1320" as="geometry"/>
                </mxCell>
                <mxCell id="sst-u1" value="1. 用户确认当前阶段的 freeze content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="330" width="180" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="sst-a1" value="agent 调 `--confirm-&lt;stage&gt;`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="320" y="330" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-s1" value="author skill 已经问完 grouped freeze，&#xa;现在只差显式 approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="600" y="330" width="240" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="sst-r1" value="runtime 写 transition approval，进入 `&lt;stage&gt;_author`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="330" width="280" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="sst-o1" value="author/draft/&#xa;`*_transition_approval.yaml`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="330" width="580" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="sst-st1" value="current_stage = `&lt;stage&gt;_author`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="330" width="480" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-a2" value="2. agent 触发 build / invoke" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="320" y="470" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-r2" value="runtime 检查：&#xa;program dir 存在吗？&#xa;stage_program.yaml 合法吗？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="450" width="280" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-o2" value="需要：&#xa;`outputs/&lt;lineage&gt;/program/...`&#xa;`stage_program.yaml`&#xa;entrypoint + README.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="450" width="580" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-st2" value="不满足时：&#xa;`awaiting_stage_program` 或 `awaiting_program_validation`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="450" width="480" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-r3" value="3. program 合法后执行 entrypoint，&#xa;校验 provenance + required outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="620" width="280" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-o3" value="author/formal/&#xa;formal artifacts&#xa;+ `program_execution_manifest.json`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="620" width="580" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-st3" value="失败时：&#xa;`PROGRAM_EXECUTION_FAILED` / `PROVENANCE_MISSING` / `OUTPUTS_INVALID`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="620" width="480" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="sst-u2" value="4. 用户确认进入 formal review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="80" y="800" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-a3" value="agent 调 `--confirm-review`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="320" y="800" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-r4" value="runtime 进入 `&lt;stage&gt;_review`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="800" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-o4" value="review/request + review/result + review/closure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="800" width="580" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sst-r5" value="5. review verdict 决定后续：&#xa;PASS / CONDITIONAL PASS -&gt; 正常推进&#xa;其他 verdict -&gt; 失败分流" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="940" width="280" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="sst-st4" value="通过后：`*_next_stage_confirmation_pending`&#xa;失败后：切 failure handling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="940" width="480" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="sst-note1" value="关键点 1：绝大多数阶段的时序都长这样，差别主要在 freeze groups 和 required outputs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="330" y="1120" width="980" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="sst-note2" value="关键点 2：placeholder、空目录、contract-only 文档不会让 runtime 放行到下一阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="1120" width="1020" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-u1" target="sst-a1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-a1" target="sst-s1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-a1" target="sst-r1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-r1" target="sst-o1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-o1" target="sst-st1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-a2" target="sst-r2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-r2" target="sst-o2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-o2" target="sst-st2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-r3" target="sst-o3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sst-e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#475569;" parent="1" source="sst-o3" target="sst-st3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
