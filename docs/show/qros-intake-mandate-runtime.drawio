                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="spg-e5" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#DC2626;fontSize=13;" parent="1" source="spg-d2" target="spg-invalid" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="spg-e6" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#16A34A;fontSize=13;" parent="1" source="spg-d2" target="spg-d3" edge="1">
